{
  "providerId": "vnytros.dev",
  "providerName": "Vnytros",
  "serviceId": "custom-domain",
  "serviceName": "Connect Custom Domain",
  "version": 1,
  "logoUrl": "https://public.assets.vnytros.dev/vnytros_logo.svg",
  "description": "Connect your custom domain to Vnytros.",
  "variableDescription": "%ip%: server IP address; %target%: CNAME destination; %txt%: verification token",
  "syncPubKeyDomain": "vnytros.dev",
  "records": [
    {
      "type": "A",
      "host": "@",
      "pointsTo": "%ip%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "www",
      "pointsTo": "%target%",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "@",
      "data": "vnytros-verify=%txt%",
      "ttl": 300
    }
  ],
  "variables": [
    {
      "name": "ip",
      "dataType": "String",
      "description": "Server IP address e.g. 1.2.3.4"
    },
    {
      "name": "target",
      "dataType": "String",
      "description": "CNAME destination e.g. app.vnytros.dev"
    },
    {
      "name": "txt",
      "dataType": "String",
      "description": "Domain verification token"
    }
  ]
}
